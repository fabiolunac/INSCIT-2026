<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="shaper_tb_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="shaper_tb" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0.000 ns"></ZoomStartTime>
      <ZoomEndTime time="1,355.001 ns"></ZoomEndTime>
      <Cursor1Time time="80.000 ns"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="258"></NameColumnWidth>
      <ValueColumnWidth column_width="58"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wvobject fp_name="/shaper_tb/clock" type="logic">
      <obj_property name="ElementShortName">clock</obj_property>
      <obj_property name="ObjectShortName">clock</obj_property>
   </wvobject>
   <wvobject fp_name="/shaper_tb/in" type="array">
      <obj_property name="ElementShortName">in[9:0]</obj_property>
      <obj_property name="ObjectShortName">in[9:0]</obj_property>
      <obj_property name="Radix">SIGNEDDECRADIX</obj_property>
      <obj_property name="WaveformStyle">STYLE_ANALOG</obj_property>
      <obj_property name="CellHeight">100</obj_property>
   </wvobject>
   <wvobject fp_name="/shaper_tb/out" type="array">
      <obj_property name="ElementShortName">out[31:0]</obj_property>
      <obj_property name="ObjectShortName">out[31:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/shaper_tb/cont" type="array">
      <obj_property name="ElementShortName">cont[63:0]</obj_property>
      <obj_property name="ObjectShortName">cont[63:0]</obj_property>
   </wvobject>
   <wvobject fp_name="/shaper_tb/data_out" type="array">
      <obj_property name="ElementShortName">data_out[31:0]</obj_property>
      <obj_property name="ObjectShortName">data_out[31:0]</obj_property>
   </wvobject>
</wave_config>
